  <property name="styleSheet">
   <string notr="true">/* 1. FONDO Y TEXTOS BASE */
QMainWindow {
    background-color: #F8FAF9;
}

QLabel {
    color: #4A5551;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 15px;
    font-weight: bold;
}

/* 2. TÍTULO PRINCIPAL (Plan Alimenticio) */
/* Asegúrate de que el objectName del label superior sea lbl_titulo_plan */
QLabel#lbl_titulo_plan {
    font-size: 20px;
    color: #043927;
    margin: 15px;
}

/* 3. BUSCADOR Y LISTA IZQUIERDA */
QLineEdit, QComboBox, QListWidget {
    background-color: white;
    border: 1px solid #E1EBE8;
    border-radius: 10px;
    padding: 8px;
    color: #333333;
}

QListWidget::item {
    padding: 8px;
    border-bottom: 1px solid #F0F5F3;
}

QListWidget::item:selected {
    background-color: #EBF3FA;
    color: #043927;
    border-radius: 5px;
}

/* 4. SECCIONES DE COMIDA (Desayuno, Comida, Cena) */
/* Aplica esto a los QListWidgets de la derecha */
QListWidget#list_desayuno, QListWidget#list_comida, QListWidget#list_cena {
    border: 2px solid #E1EBE8;
    background-color: #FFFFFF;
	border-radius: 20px;
}

/* 5. BOTONES DE ACCIÓN (Agregar / Quitar) */
QPushButton {
    background-color: white;
    border: 1px solid #D1DBD8;
    border-radius: 8px;
    padding: 6px;
    font-weight: bold;
    color: #4A5551;
}

QPushButton:hover {
    background-color: #F0F5F3;
}

/* 6. BOTONES FINALES (Imprimir y Finalizar) */
QPushButton#btn_imprimir {
    background-color: #00A36C;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 12px;
    font-size: 14px;
}

QPushButton#btn_finalizar {
    background-color: white;
    color:#333333;
    border: none;
    border-radius: 12px;
    padding: 12px;
    font-size: 14px;
}

QPushButton#btn_imprimir:hover, QPushButton#btn_finalizar:hover {
    padding: 12px;
	border: 2px solid #E1EBE8;
    background-color:#008155
 	
}
/* Frame Desayuno - Rosa */
QFrame#frame_desayuno {
    background-color: #FCE9E9;
    border: 1px solid #F8D7D7;
    border-radius: 15px;
}

/* Frame Comida - Crema */
QFrame#frame_comida {
    background-color: #FDF3E7;
    border: 1px solid #F5E5D1;
    border-radius: 15px;
}

/* Frame Cena - Azul */
QFrame#frame_cena {
    background-color: #EBF3FA;
    border: 1px solid #D5E5F2;
    border-radius: 15px;
}</string>
